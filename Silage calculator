
<div id="silage-pro-calculator" style="max-width: 600px; margin: 20px auto; padding: 30px; border: 2px solid #27ae60; border-radius: 15px; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #ffffff; box-shadow: 0 10px 25px rgba(0,0,0,0.1);">
    <h2 style="color: #27ae60; text-align: center; margin-top: 0;">Bulk Silage Order Calculator</h2>
    <p style="text-align: center; color: #666; font-size: 14px;">Estimate your herd's requirements and plan your stock.</p>
    
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-top: 20px;">
        <div>
            <label style="font-weight:bold; font-size: 14px;">Animal Type</label>
            <select id="animalType" style="width:100%; padding:10px; margin-top:5px; border-radius:5px; border:1px solid #ddd;">
                <option value="cow">Cow (HF/Crossbred)</option>
                <option value="buffalo">Buffalo (Murrah/Local)</option>
            </select>
        </div>
        <div>
            <label style="font-weight:bold; font-size: 14px;">Total Animals</label>
            <input type="number" id="herdSize" value="10" min="1" style="width:100%; padding:10px; box-sizing: border-box; margin-top:5px; border-radius:5px; border:1px solid #ddd;">
        </div>
        <div>
            <label style="font-weight:bold; font-size: 14px;">Avg. Weight (kg)</label>
            <input type="number" id="weight" value="500" style="width:100%; padding:10px; box-sizing: border-box; margin-top:5px; border-radius:5px; border:1px solid #ddd;">
        </div>
        <div>
            <label style="font-weight:bold; font-size: 14px;">Daily Milk (Ltr)</label>
            <input type="number" id="milk" value="10" style="width:100%; padding:10px; box-sizing: border-box; margin-top:5px; border-radius:5px; border:1px solid #ddd;">
        </div>
    </div>

    <label style="display:block; margin-top:15px; font-weight:bold; font-size: 14px;">Supply Duration (Days)</label>
    <select id="days" style="width:100%; padding:10px; margin-top:5px; border-radius:5px; border:1px solid #ddd; background: #fff;">
        <option value="1">1 Day (Daily Consumption)</option>
        <option value="30">30 Days (1 Month)</option>
        <option value="90">90 Days (3 Months)</option>
        <option value="180">180 Days (6 Months)</option>
    </select>

    <button onclick="calculateBulkSilage()" style="width:100%; padding:15px; background:#27ae60; color:white; border:none; border-radius:8px; margin-top:25px; cursor:pointer; font-size:18px; font-weight:bold; transition: 0.3s;">Calculate Total Requirement</button>

    <div id="resultBox" style="margin-top:25px; display:none; border-top: 2px dashed #27ae60; pt: 20px;">
        <div style="display: flex; justify-content: space-between; align-items: center; background: #f0fff4; padding: 15px; border-radius: 8px; margin-top: 15px;">
            <div>
                <span style="display:block; font-size: 14px; color: #555;">Per Animal / Day</span>
                <strong id="perAnimal" style="font-size: 20px; color: #2c3e50;">--</strong>
            </div>
            <div style="text-align: right;">
                <span style="display:block; font-size: 14px; color: #555;">Total Herd / Day</span>
                <strong id="perDayHerd" style="font-size: 20px; color: #2c3e50;">--</strong>
            </div>
        </div>

        <div style="text-align: center; margin-top: 20px; padding: 20px; background: #27ae60; color: white; border-radius: 10px;">
            <span style="font-size: 16px; opacity: 0.9;">Total Stock Required</span>
            <div id="totalStock" style="font-size: 32px; font-weight: bold; margin: 5px 0;">--</div>
            <span id="bagEstimation" style="font-size: 14px; font-style: italic;"></span>
        </div>
    </div>
</div>

<script>
function calculateBulkSilage() {
    const type = document.getElementById('animalType').value;
    const herdSize = parseFloat(document.getElementById('herdSize').value);
    const weight = parseFloat(document.getElementById('weight').value);
    const milk = parseFloat(document.getElementById('milk').value);
    const days = parseInt(document.getElementById('days').value);
    
    // Logic: Base (5% of body weight as-fed) + 0.5kg per liter of milk
    let dailyPerAnimal = (weight * 0.05) + (milk * 0.5);
    
    // Buffalo Adjustment (higher energy requirement)
    if (type === 'buffalo') {
        dailyPerAnimal = dailyPerAnimal * 1.1;
    }

    const totalDailyHerd = dailyPerAnimal * herdSize;
    const grandTotalKg = totalDailyHerd * days;
    const grandTotalTons = grandTotalKg / 1000;

    // Display Results
    document.getElementById('perAnimal').innerText = dailyPerAnimal.toFixed(1) + " kg";
    document.getElementById('perDayHerd').innerText = totalDailyHerd.toFixed(0) + " kg";
    
    if(grandTotalTons >= 1) {
        document.getElementById('totalStock').innerText = grandTotalTons.toFixed(2) + " Metric Tons";
    } else {
        document.getElementById('totalStock').innerText = grandTotalKg.toFixed(0) + " kg";
    }

    // Optional: Bag estimation (assuming 60kg bags)
    const bags = Math.ceil(grandTotalKg / 60);
    document.getElementById('bagEstimation').innerText = "Approx. " + bags + " bags (of 60kg each)";

    document.getElementById('resultBox').style.display = 'block';
}
</script>
