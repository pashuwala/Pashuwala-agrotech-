<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gallery | Pashuwala Agrotech</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --green-dark: #1a3c2e;
    --green-mid: #2d6a4f;
    --green-bright: #40916c;
    --green-light: #74c69d;
    --green-pale: #b7e4c7;
    --cream: #f8f5ee;
    --gold: #c9a84c;
    --text-dark: #0d1f17;
    --text-mid: #2d4a3a;
  }

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--green-dark);
    color: var(--cream);
    font-family: 'DM Sans', sans-serif;
    overflow-x: hidden;
    cursor: default;
  }

  /* ── Noise texture overlay ── */
  body::before {
    content: '';
    position: fixed; inset: 0; z-index: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    opacity: 0.35;
  }

  /* ── HEADER ── */
  header {
    position: relative; z-index: 10;
    padding: 0 5vw;
    background: linear-gradient(180deg, rgba(10,25,18,0.98) 0%, rgba(26,60,46,0.85) 100%);
    border-bottom: 1px solid rgba(116,198,157,0.18);
    display: flex; align-items: center; justify-content: space-between;
    height: 80px;
  }

  .logo-wrap { display: flex; align-items: center; gap: 14px; }
  .logo-icon {
    width: 46px; height: 46px;
    background: linear-gradient(135deg, var(--green-bright), var(--gold));
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px; font-weight: 900;
    color: #fff;
    box-shadow: 0 4px 20px rgba(64,145,108,0.5);
  }
  .logo-text { line-height: 1.1; }
  .logo-text strong {
    display: block;
    font-family: 'Playfair Display', serif;
    font-size: 1.15rem;
    color: var(--cream);
    letter-spacing: 0.02em;
  }
  .logo-text span {
    font-size: 0.7rem;
    color: var(--green-light);
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  nav { display: flex; gap: 32px; }
  nav a {
    color: rgba(248,245,238,0.65);
    text-decoration: none;
    font-size: 0.82rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: color 0.25s;
  }
  nav a:hover, nav a.active { color: var(--green-light); }

  /* ── HERO BANNER ── */
  .hero {
    position: relative; z-index: 2;
    height: 340px;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    text-align: center;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 110%, rgba(64,145,108,0.35) 0%, transparent 70%),
                linear-gradient(180deg, rgba(10,25,18,1) 0%, var(--green-dark) 100%);
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(116,198,157,0.12);
    border: 1px solid rgba(116,198,157,0.3);
    border-radius: 50px;
    padding: 6px 18px;
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--green-light);
    margin-bottom: 20px;
    animation: fadeUp 0.7s ease both;
  }
  .hero-badge::before { content: '🌿'; font-size: 0.9rem; }
  h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.8rem, 6vw, 5rem);
    font-weight: 900;
    line-height: 1;
    color: var(--cream);
    animation: fadeUp 0.8s 0.1s ease both;
  }
  h1 em {
    font-style: italic;
    background: linear-gradient(90deg, var(--green-light), var(--gold));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .hero-sub {
    margin-top: 16px;
    color: rgba(248,245,238,0.5);
    font-size: 0.95rem;
    letter-spacing: 0.04em;
    animation: fadeUp 0.9s 0.2s ease both;
  }

  /* ── FILTER BAR ── */
  .filter-bar {
    position: relative; z-index: 5;
    display: flex; justify-content: center; gap: 12px; flex-wrap: wrap;
    padding: 0 5vw 36px;
    animation: fadeUp 1s 0.3s ease both;
  }
  .filter-btn {
    background: rgba(45,106,79,0.18);
    border: 1px solid rgba(116,198,157,0.22);
    color: rgba(248,245,238,0.7);
    padding: 9px 22px;
    border-radius: 50px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    cursor: pointer;
    transition: all 0.25s;
  }
  .filter-btn:hover, .filter-btn.active {
    background: var(--green-bright);
    border-color: var(--green-bright);
    color: #fff;
    box-shadow: 0 4px 20px rgba(64,145,108,0.4);
    transform: translateY(-1px);
  }

  /* ── GALLERY GRID ── */
  .gallery-section {
    position: relative; z-index: 2;
    padding: 0 5vw 80px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .section-label {
    display: flex; align-items: center; gap: 16px;
    margin-bottom: 24px;
  }
  .section-label h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    color: var(--cream);
  }
  .section-label .line {
    flex: 1; height: 1px;
    background: linear-gradient(90deg, rgba(116,198,157,0.3), transparent);
  }
  .section-label .tag {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--green-light);
    background: rgba(116,198,157,0.1);
    padding: 4px 12px;
    border-radius: 20px;
    border: 1px solid rgba(116,198,157,0.2);
  }

  /* Masonry-style grid */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: 80px;
    gap: 14px;
  }

  .gallery-item {
    position: relative;
    overflow: hidden;
    border-radius: 14px;
    background: rgba(45,106,79,0.15);
    border: 1px solid rgba(116,198,157,0.1);
    cursor: pointer;
    transition: transform 0.4s cubic-bezier(.22,.9,.36,1), box-shadow 0.4s;
  }
  .gallery-item:hover {
    transform: scale(1.02) translateY(-4px);
    box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 0 1px rgba(116,198,157,0.3);
    z-index: 3;
  }

  /* Specific grid placements */
  .item-1 { grid-column: 1/6; grid-row: 1/6; }
  .item-2 { grid-column: 6/10; grid-row: 1/4; }
  .item-3 { grid-column: 10/13; grid-row: 1/4; }
  .item-4 { grid-column: 6/13; grid-row: 4/8; }

  /* Video items */
  .vid-1 { grid-column: 1/7; grid-row: 6/12; }
  .vid-2 { grid-column: 7/13; grid-row: 8/12; }
  .item-bales { grid-column: 7/13; grid-row: 6/8; }

  .gallery-item img,
  .gallery-item video {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(.22,.9,.36,1);
  }
  .gallery-item:hover img,
  .gallery-item:hover video { transform: scale(1.06); }

  /* Overlay on hover */
  .item-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(10,25,18,0.85) 100%);
    opacity: 0;
    transition: opacity 0.35s;
    display: flex; align-items: flex-end;
    padding: 20px;
  }
  .gallery-item:hover .item-overlay { opacity: 1; }

  .item-overlay-content { }
  .item-title {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    color: #fff;
    line-height: 1.3;
  }
  .item-meta {
    font-size: 0.72rem;
    color: var(--green-pale);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-top: 4px;
  }

  /* Video badge */
  .video-badge {
    position: absolute; top: 14px; left: 14px;
    background: rgba(10,25,18,0.75);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(116,198,157,0.3);
    border-radius: 8px;
    padding: 5px 12px;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    color: var(--green-light);
    display: flex; align-items: center; gap: 6px;
    text-transform: uppercase;
  }
  .video-badge::before { content: '▶'; font-size: 0.6rem; color: var(--gold); }

  .play-btn {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    width: 62px; height: 62px;
    background: rgba(64,145,108,0.8);
    backdrop-filter: blur(10px);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem;
    color: #fff;
    opacity: 0;
    transition: opacity 0.3s, transform 0.3s;
    pointer-events: none;
  }
  .gallery-item:hover .play-btn { opacity: 1; transform: translate(-50%,-50%) scale(1.1); }

  /* ── STATS ROW ── */
  .stats-row {
    position: relative; z-index: 2;
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: rgba(116,198,157,0.08);
    border-top: 1px solid rgba(116,198,157,0.12);
    border-bottom: 1px solid rgba(116,198,157,0.12);
    margin-bottom: 60px;
    overflow: hidden;
  }
  .stat-box {
    padding: 36px 30px;
    text-align: center;
    background: rgba(10,25,18,0.6);
    transition: background 0.3s;
  }
  .stat-box:hover { background: rgba(45,106,79,0.25); }
  .stat-num {
    font-family: 'Playfair Display', serif;
    font-size: 2.8rem;
    font-weight: 700;
    color: var(--green-light);
    line-height: 1;
  }
  .stat-unit { font-size: 1.2rem; color: var(--gold); }
  .stat-label {
    margin-top: 8px;
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(248,245,238,0.5);
  }

  /* ── LIGHTBOX ── */
  .lightbox {
    display: none;
    position: fixed; inset: 0; z-index: 1000;
    background: rgba(5,14,10,0.96);
    backdrop-filter: blur(20px);
    align-items: center; justify-content: center;
    animation: lbFadeIn 0.3s ease;
  }
  .lightbox.open { display: flex; }
  .lb-inner {
    position: relative;
    max-width: 90vw; max-height: 88vh;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 40px 120px rgba(0,0,0,0.8), 0 0 0 1px rgba(116,198,157,0.15);
  }
  .lb-inner img, .lb-inner video {
    display: block;
    max-width: 90vw; max-height: 85vh;
    object-fit: contain;
  }
  .lb-close {
    position: absolute; top: 16px; right: 16px;
    width: 40px; height: 40px;
    background: rgba(10,25,18,0.8);
    border: 1px solid rgba(116,198,157,0.25);
    border-radius: 50%;
    color: var(--cream);
    font-size: 1.2rem;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s;
    z-index: 10;
  }
  .lb-close:hover { background: rgba(64,145,108,0.6); }
  .lb-caption {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 16px 24px;
    background: linear-gradient(180deg, transparent, rgba(5,14,10,0.9));
    font-size: 0.88rem;
    color: rgba(248,245,238,0.8);
  }

  /* ── FOOTER ── */
  footer {
    position: relative; z-index: 2;
    padding: 40px 5vw;
    border-top: 1px solid rgba(116,198,157,0.12);
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 16px;
  }
  .footer-brand {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    color: var(--cream);
  }
  .footer-brand span { color: var(--green-light); }
  footer p {
    font-size: 0.78rem;
    color: rgba(248,245,238,0.35);
  }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes lbFadeIn {
    from { opacity: 0; } to { opacity: 1; }
  }

  /* Staggered entrance for gallery items */
  .gallery-item { animation: fadeUp 0.7s ease both; }
  .item-1 { animation-delay: 0.15s; }
  .item-2 { animation-delay: 0.25s; }
  .item-3 { animation-delay: 0.3s; }
  .item-4 { animation-delay: 0.35s; }
  .vid-1  { animation-delay: 0.4s; }
  .vid-2  { animation-delay: 0.45s; }
  .item-bales { animation-delay: 0.42s; }

  /* Decorative dot grid */
  .dot-grid {
    position: fixed; top: 0; left: 0; z-index: 1;
    width: 100%; height: 100%;
    background-image: radial-gradient(circle, rgba(116,198,157,0.06) 1px, transparent 1px);
    background-size: 36px 36px;
    pointer-events: none;
  }

  /* Floating green orb */
  .orb {
    position: fixed; z-index: 1;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }
  .orb-1 { width: 500px; height: 500px; top: -100px; right: -100px; background: rgba(64,145,108,0.12); }
  .orb-2 { width: 400px; height: 400px; bottom: 100px; left: -80px; background: rgba(45,106,79,0.1); }

  @media (max-width: 768px) {
    .gallery-grid {
      grid-template-columns: 1fr 1fr;
      grid-auto-rows: 200px;
    }
    .item-1, .item-2, .item-3, .item-4,
    .vid-1, .vid-2, .item-bales {
      grid-column: span 2;
      grid-row: span 1;
    }
    .stats-row { grid-template-columns: 1fr 1fr; }
    nav { display: none; }
  }
</style>
</head>
