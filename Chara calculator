<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pashuwala Agrotech</title>

<style>
body {
    margin: 0;
    font-family: 'Segoe UI', sans-serif;
    background: #f4fbf6;
}

/* HEADER */
header {
    background: linear-gradient(135deg, #27ae60, #145a32);
    color: white;
    padding: 20px;
    text-align: center;
}

header h1 {
    margin: 0;
    font-size: 28px;
}

header p {
    margin: 5px 0 0;
    font-size: 14px;
    opacity: 0.9;
}

/* CONTAINER */
.container {
    max-width: 1100px;
    margin: auto;
    padding: 20px;
}

/* CARD */
.card {
    background: white;
    border-radius: 15px;
    padding: 25px;
    box-shadow: 0 8px 20px rgba(0,0,0,0.08);
    margin-bottom: 20px;
}

/* GRID */
.grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
}

@media(max-width: 768px) {
    .grid {
        grid-template-columns: 1fr;
    }
}

/* FORM */
label {
    font-weight: bold;
    margin-top: 12px;
    display: block;
}

input, select {
    width: 100%;
    padding: 12px;
    margin-top: 5px;
    border-radius: 8px;
    border: 1px solid #ddd;
    font-size: 15px;
}

/* BUTTON */
button {
    width: 100%;
    padding: 14px;
    margin-top: 18px;
    border: none;
    border-radius: 10px;
    background: #27ae60;
    color: white;
    font-size: 17px;
    font-weight: bold;
    cursor: pointer;
    transition: 0.3s;
}

button:hover {
    background: #1e8449;
}

/* RESULT */
.result {
    display: none;
    text-align: center;
    margin-top: 20px;
    background: #eafaf1;
    padding: 20px;
    border-radius: 12px;
}

.result h2 {
    color: #27ae60;
    margin: 10px 0;
}

/* FEATURE BOX */
.feature {
    text-align: center;
}

.feature h3 {
    color: #27ae60;
}

/* FOOTER */
footer {
    background: #145a32;
    color: white;
    text-align: center;
    padding: 15px;
    font-size: 13px;
}
</style>
</head>

<body>

<header>
    <h1>Pashuwala Agrotech</h1>
    <p>Advanced Dairy Feed & Silage Management System</p>
</header>

<div class="container">

    <!-- FEATURES -->
    <div class="grid">
        <div class="card feature">
            <h3>🌽 Smart Silage Planning</h3>
            <p>Accurate feed calculation based on weight & milk yield.</p>
        </div>
        <div class="card feature">
            <h3>🐄 Dairy Optimization</h3>
            <p>Improve production with scientific feeding ratios.</p>
        </div>
    </div>

    <!-- CALCULATOR -->
    <div class="card">
        <h2 style="text-align:center; color:#27ae60;">Silage Calculator</h2>

        <div class="grid">
            <div>
                <label>Animal Type</label>
                <select id="type">
                    <option value="cow">Cow (HF/Jersey)</option>
                    <option value="buffalo">Buffalo (Murrah)</option>
                </select>

                <label>Total Animals</label>
                <input type="number" id="herd" value="10">

                <label>Average Weight (kg)</label>
                <input type="number" id="weight" value="500">
            </div>

            <div>
                <label>Milk Production (L/day)</label>
                <input type="number" id="milk" value="10">

                <label>Stock Duration</label>
                <select id="days">
                    <option value="1">1 Day</option>
                    <option value="30">30 Days</option>
                    <option value="90">90 Days</option>
                </select>

                <button onclick="calculate()">Calculate Requirement</button>
            </div>
        </div>

        <div class="result" id="resultBox">
            <p>Total Silage Required</p>
            <h2 id="total"></h2>
            <small id="per"></small>
        </div>
    </div>

</div>

<footer>
    © 2026 Pashuwala Agrotech | Smart Farming Solutions
</footer>

<script>
function calculate() {
    let type = document.getElementById("type").value;
    let herd = parseFloat(document.getElementById("herd").value);
    let weight = parseFloat(document.getElementById("weight").value);
    let milk = parseFloat(document.getElementById("milk").value);
    let days = parseInt(document.getElementById("days").value);

    let daily = (weight * 0.05) + (milk * 0.5);

    if (type === "buffalo") {
        daily *= 1.1;
    }

    let total = daily * herd * days;

    let output = total >= 1000
        ? (total / 1000).toFixed(2) + " Tons"
        : total.toFixed(0) + " kg";

    document.getElementById("total").innerText = output;
    document.getElementById("per").innerText =
        "Per Animal: " + daily.toFixed(1) + " kg/day";

    document.getElementById("resultBox").style.display = "block";
}
</script>

</body>
</html>

